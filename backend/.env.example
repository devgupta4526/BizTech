# Neon (or any Postgres). Set the real value in Render / local .env — never commit secrets.
# If Prisma fails to connect, try removing channel_binding=require from the URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

PORT=3001
NODE_ENV=development

# Comma-separated origins for CORS (your Vercel URL). Example:
# FRONTEND_URL=https://factory-dashboard.vercel.app
